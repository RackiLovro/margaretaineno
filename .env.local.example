# The public HTTPS URL of your home storage server, exposed via
# Cloudflare Tunnel. Example: https://margareta-storage.example.com
STORAGE_BASE_URL=https://your-tunnel-subdomain.example.com

# Shared secret — MUST match STORAGE_SECRET on the home server.
STORAGE_SECRET=replace-with-a-long-random-secret-string

# Optional: set to a password string to restrict uploads/uploads listing
# to people who visit with ?k=password in the URL. Keep empty for a
# public wedding gallery anyone with the link can use.
GALLERY_PASSWORD=